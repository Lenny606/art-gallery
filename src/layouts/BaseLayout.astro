---
import '../styles/global.css';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';
import { ui } from '../i18n/ui';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
	lang?: keyof typeof ui;
}

const { title, description = "Art Gallery - A premium exhibition of digital arts" } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<!DOCTYPE html>
<html lang={lang} class="bg-[#fafafa] text-[#1a1a1a] selection:bg-black/10">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
	</head>
	<body class="min-h-screen font-inter antialiased overflow-x-hidden">
		<header class="w-full px-6 py-8 md:px-8 md:py-12 relative z-[100]">
			<nav class="flex items-center w-full max-w-7xl mx-auto">
				<!-- Logo / Brand (Now on the left) -->
				<div class="mr-auto">
					<a href={translatePath('/')} class="text-sm md:text-xl uppercase tracking-widest font-black shrink-0">Art Gallery.</a>
				</div>

				<!-- Desktop Nav (Now pushed to the right) -->
				<div class="hidden md:flex gap-12 items-center mr-12">
					<a href={translatePath('/')} class="text-xs uppercase tracking-widest font-bold opacity-30 hover:opacity-100 transition-opacity">{t('nav.home')}</a>
					<a href={translatePath('/galerie')} class="text-xs uppercase tracking-widest font-bold opacity-30 hover:opacity-100 transition-opacity">{t('nav.gallery')}</a>
					<a href={translatePath('/kontakt')} class="text-xs uppercase tracking-widest font-bold opacity-30 hover:opacity-100 transition-opacity">{t('nav.contact')}</a>
				</div>
				
				<!-- Right Side: Desktop Lang Switcher & Mobile Hamburger -->
				<div class="flex gap-6 items-center">
					<!-- Desktop Language Switcher (Hidden on mobile) -->
					<div class="hidden md:flex gap-3">
						{['cs', 'en', 'de'].map((l) => (
							<a 
								href={l === 'cs' ? '/' : `/${l}/`} 
								class={`text-[10px] uppercase tracking-tighter ${lang === l ? 'font-bold underline underline-offset-4' : 'opacity-30'}`}
							>
								{l}
							</a>
						))}
					</div>

					<!-- Hamburger Button -->
					<button id="menu-toggle" class="md:hidden p-2 -mr-2 focus:outline-none" aria-label="Open Menu">
						<div class="w-6 h-4 relative flex flex-col justify-between">
							<span class="w-full h-[1.5px] bg-[#1a1a1a]"></span>
							<span class="w-full h-[1.5px] bg-[#1a1a1a]"></span>
							<span class="w-full h-[1.5px] bg-[#1a1a1a]"></span>
						</div>
					</button>
				</div>
			</nav>

			<!-- Mobile Menu Overlay -->
			<div id="mobile-menu" class="fixed inset-0 bg-[#fafafa] z-[110] flex flex-col p-8 translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.85,0,0.15,1)] md:hidden overflow-y-auto">
				<!-- Mobile Menu Header (Close Button) -->
				<div class="flex justify-end mb-12 shrink-0">
					<button id="menu-close" class="p-2 -mr-2 text-xs uppercase tracking-widest font-bold focus:outline-none" aria-label="Close Menu">
						Zavřít [×]
					</button>
				</div>

				<!-- Mobile Content wrapper -->
				<div class="flex flex-col gap-16">
					<!-- Mobile Nav Links -->
					<nav class="flex flex-col gap-8">
						<a href={translatePath('/')} class="mobile-link text-5xl font-black">{t('nav.home')}</a>
						<a href={translatePath('/galerie')} class="mobile-link text-4xl font-black opacity-40 hover:opacity-100 transition-opacity">{t('nav.gallery')}</a>
						<a href={translatePath('/kontakt')} class="mobile-link text-4xl font-black opacity-40 hover:opacity-100 transition-opacity">{t('nav.contact')}</a>
					</nav>

					<!-- Mobile Language Switcher (Moved here for better visibility) -->
					<div class="pt-8 border-t border-black/5">
						<p class="text-[10px] uppercase tracking-widest font-bold opacity-30 mb-6 font-bold">Jazyk / Language</p>
						<div class="flex gap-8">
							{['cs', 'en', 'de'].map((l) => (
								<a 
									href={l === 'cs' ? '/' : `/${l}/`} 
									class={`text-2xl uppercase tracking-tight ${lang === l ? 'font-black underline underline-offset-8' : 'opacity-40 hover:opacity-100 transition-opacity'}`}
								>
									{l}
								</a>
							))}
						</div>
					</div>
				</div>

				<!-- Extra spacing at bottom for scroll -->
				<div class="mt-24 shrink-0"></div>
			</div>
		</header>

		<main class="relative z-10">
			<slot />
		</main>

		<Footer />

		<script>
			const toggle = document.getElementById('menu-toggle');
			const close = document.getElementById('menu-close');
			const menu = document.getElementById('mobile-menu');
			const links = document.querySelectorAll('.mobile-link');

			let isOpen = false;

			function openMenu() {
				menu?.classList.remove('translate-x-full');
				document.body.style.overflow = 'hidden';
				isOpen = true;
			}

			function closeMenu() {
				menu?.classList.add('translate-x-full');
				document.body.style.overflow = '';
				isOpen = false;
			}

			toggle?.addEventListener('click', openMenu);
			close?.addEventListener('click', closeMenu);
			
			// Close on link click
			links.forEach(link => link.addEventListener('click', closeMenu));

			// Accessibility: Close on Escape or Enter (when open)
			window.addEventListener('keydown', (e) => {
				if (isOpen && (e.key === 'Escape' || e.key === 'Enter')) {
					closeMenu();
				}
			});
		</script>
	</body>
</html>

<style is:global>
	h1, h2, h3, h4, h5, h6 {
		font-family: 'Playfair Display', serif;
	}

	html {
		scroll-behavior: smooth;
	}
</style>
