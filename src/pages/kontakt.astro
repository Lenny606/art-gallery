---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={`Art Gallery | ${t('contact.title')}`} lang={lang}>
	<div class="max-w-7xl mx-auto px-6 md:px-8 py-12 md:py-24">
		<!-- Header -->
		<div class="header-section mb-16 md:mb-24">
			<h1 class="text-6xl md:text-9xl font-black mb-8 md:mb-12">{t('contact.title')}.</h1>
			<div class="h-[1px] w-1/3 bg-black/10"></div>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-32">
			<!-- Info Column -->
			<div class="info-column">
				<p class="text-xl md:text-2xl text-stone-500 mb-16 leading-relaxed">
					{t('contact.description')}
				</p>

				<div class="space-y-12">
					<!-- Contact Details -->
					<div class="detail-group">
						<h2 class="section-label">{t('contact.visitUs')}</h2>
						<p class="detail-value text-2xl font-bold mt-4">Vodičkova 123, 110 00 Praha 1</p>
					</div>

					<div class="grid grid-cols-1 sm:grid-cols-2 gap-12">
						<div class="detail-group">
							<h2 class="section-label">{t('footer.email')}</h2>
							<a href="mailto:hello@artgallery.com" class="detail-value block text-xl font-bold mt-2 hover:opacity-50 transition-opacity underline underline-offset-4">hello@artgallery.com</a>
						</div>
						<div class="detail-group">
							<h2 class="section-label">{t('footer.phone')}</h2>
							<a href="tel:+420123456789" class="detail-value block text-xl font-bold mt-2 hover:opacity-50 transition-opacity underline underline-offset-4">+420 123 456 789</a>
						</div>
					</div>

					<!-- Open Hours -->
					<div class="detail-group pt-8 border-t border-black/5">
						<h2 class="section-label">{t('contact.hours')}</h2>
						<p class="detail-value text-lg text-stone-600 mt-4 leading-relaxed">
							{t('contact.hours.value')}
						</p>
					</div>
				</div>
			</div>

			<!-- Image Column -->
			<div class="image-column">
				<div class="skeleton-wrapper group overflow-hidden bg-stone-100 rounded-2xl aspect-[4/5] relative">
					<!-- Shimmer Effect -->
					<div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full animate-shimmer"></div>
					<div class="absolute inset-0 flex flex-col items-center justify-center p-12 text-center">
						<div class="w-12 h-12 border border-black/10 rounded-full flex items-center justify-center mb-6 opacity-20 group-hover:opacity-40 transition-opacity">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect><circle cx="9" cy="9" r="2"></circle><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path></svg>
						</div>
						<span class="text-[10px] uppercase tracking-[0.2em] font-black opacity-10">Gallery Entrance Space</span>
					</div>
				</div>
				<p class="mt-6 text-[10px] uppercase tracking-widest font-bold opacity-30 text-right italic">
					Visual Representation (Coming Soon)
				</p>
			</div>
		</div>
	</div>
</BaseLayout>

<style>
	.section-label {
		font-size: 0.625rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-weight: 800;
		color: rgba(26, 26, 26, 0.4);
	}

	.animate-shimmer {
		animation: shimmer 2.5s infinite linear;
	}

	@keyframes shimmer {
		100% {
			transform: translateX(100%);
		}
	}

	.skeleton-wrapper {
		box-shadow: inset 0 0 40px rgba(0,0,0,0.02);
	}
</style>
