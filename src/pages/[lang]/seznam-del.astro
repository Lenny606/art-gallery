---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';
import ArtworkArchive from '../../components/ArtworkArchive.astro';
import { ui } from '../../i18n/ui';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const descriptions = {
    en: 'A complete overview of our collection. This page serves as a static index of all available and sold works. For detailed information and interactive tours, please visit our Gallery.',
    de: 'Ein vollständiger Überblick über unsere Sammlung. Diese Seite dient als statisches Verzeichnis aller verfügbaren und verkauften Werke. Für detaillierte Informationen und interaktive Touren besuchen Sie bitte unsere Galerie.'
};

const titles = {
    en: 'ARCHIVE',
    de: 'ARCHIV'
};
---

<BaseLayout title={`Art Gallery | ${t('nav.list')}`} lang={lang}>
    <main class="max-w-7xl mx-auto px-6 md:px-8 py-12 md:py-24">
        <!-- Header -->
        <header class="mb-24 md:mb-32">
            <h1 class="text-7xl md:text-[10rem] font-black tracking-tighter leading-none mb-12 uppercase">
                {titles[lang as keyof typeof titles]}<span class="text-stone-300">.</span>
            </h1>
            <div class="h-[2px] w-24 bg-black mb-12"></div>
            <p class="text-xl md:text-2xl text-stone-500 max-w-2xl leading-relaxed">
                {descriptions[lang as keyof typeof descriptions]}
                <a href={translatePath('/galerie')} class="text-black underline underline-offset-8 decoration-1 hover:decoration-2 transition-all block mt-6">
                    {t('nav.gallery')}
                </a>
            </p>
        </header>

        <!-- Archive List -->
        <ArtworkArchive />
    </main>
</BaseLayout>
