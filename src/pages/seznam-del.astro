---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ArtworkArchive from '../components/ArtworkArchive.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={`Art Gallery | ${t('nav.list')}`} lang={lang}>
    <main class="max-w-7xl mx-auto px-6 md:px-8 py-12 md:py-24">
        <!-- Header -->
        <header class="mb-24 md:mb-32">
            <h1 class="text-7xl md:text-[10rem] font-black tracking-tighter leading-none mb-12">
                ARCHIV<span class="text-stone-300">.</span>
            </h1>
            <div class="h-[2px] w-24 bg-black mb-12"></div>
            <p class="text-xl md:text-2xl text-stone-500 max-w-2xl leading-relaxed">
                Kompletní přehled naší sbírky. Tato stránka slouží jako statický index všech dostupných i prodaných děl. Pro podrobné informace a interaktivní prohlídku navštivte naši <a href="/galerie" class="text-black underline underline-offset-8 decoration-1 hover:decoration-2 transition-all">Galerii</a>.
            </p>
        </header>

        <!-- Archive List -->
        <ArtworkArchive />
    </main>
</BaseLayout>
