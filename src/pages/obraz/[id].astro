---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArtworkHero from '../../components/ArtworkHero.astro';
import ArtworkInfo from '../../components/ArtworkInfo.astro';
import ArtworkGallery from '../../components/ArtworkGallery.astro';
import artworks from '../../data/artworks.json';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return artworks.map((art) => ({
    params: { id: art.id }
  }));
}

const { id } = Astro.params;
const art = artworks.find(a => a.id === id);

if (!art) {
    return Astro.redirect('/404');
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Localized values
const title = art.title[lang as keyof typeof art.title] || art.title.cs || art.title.en;
const genreLabel = t(`categories.${art.genre}` as any);

const labels = {
    dimensions: 'Rozměry',
    year: 'Rok',
    status: 'Stav'
};
---

<BaseLayout title={`${title} | Art Gallery`} lang={lang}>
    <div class="artwork-detail-page bg-white min-h-screen">
        <!-- Temporary Debug Header -->
        <div class="bg-black text-white p-2 text-[10px] uppercase tracking-widest text-center">
            Detail: {title} (ID: {id})
        </div>

        <ArtworkHero 
            title={title} 
            genre={genreLabel} 
            image={art.mainImage} 
        />

        <div class="max-w-7xl mx-auto px-6 md:px-8">
            <ArtworkInfo 
                dimensions={art.dimensions} 
                year={art.year} 
                status={art.status}
                labels={labels}
            />
            
            <div class="description py-16 md:py-24 max-w-3xl">
                <h2 class="text-4xl font-black mb-8 uppercase tracking-tighter">O díle</h2>
                <div class="h-1.5 w-16 bg-black mb-10"></div>
                <p class="text-2xl text-stone-600 leading-relaxed font-serif italic">
                    Tento kus představuje unikátní dialog mezi formou a obsahem. "{title}" je součástí hlubšího průzkumu média {genreLabel}. Každý detail byl pečlivě zvažován pro dosažení maximální vizuální harmonie a emocionálního dopadu.
                </p>
            </div>
        </div>

        <ArtworkGallery images={art.images} />
        
        <!-- Navigation Back -->
        <div class="max-w-7xl mx-auto px-6 md:px-8 pb-40">
            <a href="/galerie" class="inline-flex items-center gap-6 group">
                <div class="w-16 h-16 rounded-full border border-stone-200 flex items-center justify-center group-hover:bg-black group-hover:text-white transition-all duration-700 shadow-lg">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M19 12H5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M12 19L5 12L12 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span class="text-xs font-black uppercase tracking-[0.3em] group-hover:translate-x-2 transition-transform duration-500">Zpět do galerie</span>
            </a>
        </div>
    </div>
</BaseLayout>
