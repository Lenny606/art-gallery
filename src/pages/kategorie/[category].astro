---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { category: 'abstract' }, props: { key: 'categories.abstract' } },
    { params: { category: 'minimal' }, props: { key: 'categories.minimal' } },
    { params: { category: 'portraits' }, props: { key: 'categories.portraits' } },
    { params: { category: 'digital' }, props: { key: 'categories.digital' } },
  ];
}

const { category } = Astro.params;
const { key } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const title = t(key as any);
---

<BaseLayout title={`${title} | Art Gallery`} lang={lang}>
    <div class="max-w-7xl mx-auto px-6 md:px-8 py-12 md:py-24">
        <div class="mb-16">
            <p class="text-[10px] uppercase tracking-widest font-bold opacity-30 mb-4">{category}</p>
            <h1 class="text-6xl md:text-9xl font-black mb-8">{title}.</h1>
            <div class="h-[1px] w-full bg-black/10 mb-12"></div>
        </div>

        <!-- Skeleton Grid for the category -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {[1, 2, 3, 4, 5, 6].map((i) => (
                <div class="group">
                    <div class="aspect-[3/4] bg-stone-200 mb-4 relative overflow-hidden">
                        <div class="absolute inset-0 bg-stone-300 transform scale-100 group-hover:scale-105 transition-transform duration-700"></div>
                    </div>
                    <h3 class="font-bold uppercase text-sm tracking-tight">{title} Study #{i}</h3>
                </div>
            ))}
        </div>
    </div>
</BaseLayout>
