---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const artworks = [
    { id: 1, height: 'aspect-[3/4]' },
    { id: 2, height: 'aspect-[4/5]' },
    { id: 3, height: 'aspect-[4/3]' },
    { id: 4, height: 'aspect-[4/5]' },
    { id: 5, height: 'aspect-[3/4]' },
    { id: 6, height: 'aspect-square' },
];
---

<section class="max-w-7xl mx-auto px-6 md:px-8 py-12 md:py-24">
    <div class="mb-16">
        <h2 class="text-4xl md:text-6xl font-black mb-6">{t('featured.title')}</h2>
        <p class="text-stone-500 max-w-xl text-lg">{t('featured.subTitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
        {artworks.map((art) => (
            <div class="group cursor-pointer">
                <div class={`w-full ${art.height} bg-stone-200 mb-6 relative overflow-hidden`}>
                    <div class="absolute inset-0 bg-stone-300 transform scale-100 group-hover:scale-105 transition-transform duration-700"></div>
                </div>
                <div class="space-y-1">
                    <h3 class="font-black text-xl uppercase tracking-tighter">Artwork Title No. {art.id}</h3>
                    <div class="flex justify-between items-center opacity-40">
                        <p class="text-[10px] uppercase font-bold tracking-widest">Artist Name</p>
                        <p class="text-[10px] uppercase font-bold tracking-widest">2026</p>
                    </div>
                </div>
            </div>
        ))}
    </div>

    <div class="mt-20 flex justify-center">
        <button class="px-12 py-5 border border-black text-[10px] font-black uppercase tracking-widest hover:bg-black hover:text-white transition-all duration-300">
            {t('hero.cta')}
        </button>
    </div>
</section>
