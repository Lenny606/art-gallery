---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';
import artworks from '../data/artworks.json';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Get first 6 artworks as featured
const featuredArtworks = artworks.slice(0, 6);
---

<section class="max-w-7xl mx-auto px-6 md:px-8 py-12 md:py-24">
    <div class="mb-16">
        <h2 class="text-4xl md:text-6xl font-black mb-6">{t('featured.title')}</h2>
        <p class="text-stone-500 max-w-xl text-lg">{t('featured.subTitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
        {featuredArtworks.map((art) => (
            <a href={translatePath(`/obraz/${art.id}`)} class="group cursor-pointer block">
                <div class={`w-full aspect-[3/4] bg-stone-100 mb-6 relative overflow-hidden rounded-lg`}>
                    <img 
                        src={art.mainImage} 
                        alt={art.title[lang as keyof typeof art.title] || art.title.en} 
                        class="absolute inset-0 w-full h-full object-cover transform scale-100 group-hover:scale-105 transition-transform duration-700" 
                    />
                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-500"></div>
                </div>
                <div class="space-y-1">
                    <h3 class="font-black text-xl uppercase tracking-tighter">
                        {art.title[lang as keyof typeof art.title] || art.title.en}
                    </h3>
                    <div class="flex justify-between items-center opacity-40">
                        <p class="text-[10px] uppercase font-bold tracking-widest">{t(`categories.${art.genre}` as any)}</p>
                        <p class="text-[10px] uppercase font-bold tracking-widest">{art.year}</p>
                    </div>
                </div>
            </a>
        ))}
    </div>

    <div class="mt-20 flex justify-center">
        <a href={translatePath('/galerie')} class="px-12 py-5 border border-black text-[10px] font-black uppercase tracking-widest hover:bg-black hover:text-white transition-all duration-300">
            {t('hero.cta')}
        </a>
    </div>
</section>
