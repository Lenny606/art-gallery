---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const categories = [
    { id: 'abstract', key: 'categories.abstract' },
    { id: 'minimal', key: 'categories.minimal' },
    { id: 'portraits', key: 'categories.portraits' },
    { id: 'digital', key: 'categories.digital' },
    { id: 'classic', key: 'categories.abstract' }, // Reusing for skeleton variety
];
---

<section class="max-w-7xl mx-auto px-6 md:px-8 py-12 md:py-24 overflow-hidden">
    <div class="flex justify-between items-end mb-12">
        <div>
            <p class="text-[10px] uppercase tracking-widest font-bold opacity-30 mb-4">{t('categories.title')}</p>
            <h2 class="text-4xl md:text-6xl font-black">{t('categories.title')}</h2>
        </div>
        <div class="hidden md:flex gap-4">
            <button class="p-4 border border-black/5 hover:bg-black/5 transition-colors" id="prev-btn" aria-label="Previous">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5"/></svg>
            </button>
            <button class="p-4 border border-black/5 hover:bg-black/5 transition-colors" id="next-btn" aria-label="Next">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.5"/></svg>
            </button>
        </div>
    </div>

    <div class="flex gap-6 overflow-x-auto no-scrollbar scroll-smooth snap-x snap-mandatory" id="slider-container">
        {categories.map((cat) => (
            <a href={translatePath(`/kategorie/${cat.id}`)} class="min-w-[80vw] md:min-w-[400px] aspect-[4/5] bg-stone-200 snap-start group cursor-pointer relative overflow-hidden block">
                <div class="absolute inset-0 bg-stone-300 transform scale-100 group-hover:scale-105 transition-transform duration-700"></div>
                <div class="absolute inset-x-0 bottom-0 p-8 bg-gradient-to-t from-black/20 to-transparent">
                    <p class="text-xs uppercase tracking-widest font-bold text-white mb-2">{t(cat.key as any)}</p>
                    <h3 class="text-2xl font-black text-white italic">0{categories.indexOf(cat) + 1}</h3>
                </div>
            </a>
        ))}
    </div>
</section>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>

<script>
    const container = document.getElementById('slider-container');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');

    if (container) {
        prevBtn?.addEventListener('click', () => {
            container.scrollLeft -= 400;
        });

        nextBtn?.addEventListener('click', () => {
            container.scrollLeft += 400;
        });
    }
</script>
