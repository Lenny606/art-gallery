---
interface Props {
  title: string;
  genre: string;
  image: string;
}

const { title, genre, image } = Astro.props;
---

<section class="artwork-hero relative min-h-[60vh] md:min-h-[80vh] flex items-center md:items-end pb-12 md:pb-24 overflow-hidden bg-stone-100">
    <!-- Background Blur Image -->
    <div class="absolute inset-0 z-0">
        <img src={image} alt="" class="w-full h-full object-cover blur-3xl opacity-40 scale-110" />
    </div>

    <div class="max-w-7xl mx-auto px-6 md:px-8 w-full relative z-10 pt-24 md:pt-32">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center md:items-end">
            <!-- Mobile Main Image -->
            <div class="lg:hidden w-full mb-8 cursor-pointer gallery-item" data-index="0">
                <div class="aspect-[4/5] overflow-hidden rounded-2xl shadow-xl">
                    <img src={image} alt={title} class="w-full h-full object-cover" loading="eager" />
                </div>
            </div>
            
            <div class="lg:col-span-8">
                <p class="text-[10px] md:text-xs uppercase tracking-[0.5em] font-black text-stone-500 mb-6 flex items-center gap-4">
                    <span class="w-12 h-[1px] bg-stone-400"></span>
                    {genre}
                </p>
                <h1 class="text-5xl md:text-[clamp(4rem,10vw,10rem)] font-black mb-0 tracking-tighter leading-[0.85] break-words">
                    {title}
                </h1>
            </div>
            
            <div class="lg:col-span-4 hidden lg:block cursor-pointer gallery-item" data-index="0">
                <div class="aspect-[3/4] overflow-hidden rounded-3xl shadow-2xl transform hover:scale-[1.02] transition-transform duration-700">
                    <img src={image} alt={title} class="w-full h-full object-cover" loading="eager" />
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    const heroItems = document.querySelectorAll('.artwork-hero .gallery-item');
    heroItems.forEach(item => {
        item.addEventListener('click', () => {
            document.dispatchEvent(new CustomEvent('open-lightbox', {
                detail: { index: 0 }
            }));
        });
    });
</script>

<style>
    h1 {
        text-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
</style>
